# llm-exporter — Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────
METRICS_PORT=9090
SCRAPE_INTERVAL=300        # seconds between probes (default: 5 min)
LOG_LEVEL=info             # debug | info | warn | error

# ─── Supabase (optional — takes priority over config.yaml) ────
# If set, keys are loaded from the credentials table
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_your_service_role_key_here

# ─── Inline API Keys (alternative to config.yaml + Supabase) ──
# You can also declare keys directly here.
# Format: LLM_{PROVIDER}_{KEY_ID}=sk-xxx
# Key ID is used as the `key_id` Prometheus label.

# Anthropic
LLM_ANTHROPIC_MAX1=sk-ant-your-key-here
# LLM_ANTHROPIC_MAX2=sk-ant-second-key-here

# OpenAI
LLM_OPENAI_MAIN=sk-proj-your-key-here

# OpenRouter
LLM_OPENROUTER_MAIN=sk-or-v1-your-key-here

# XAI (Grok)
LLM_XAI_MAIN=xai-your-key-here

# Mistral
LLM_MISTRAL_MAIN=your-mistral-key-here

# Gemini
LLM_GEMINI_MAIN=AIzaSy-your-key-here

# ElevenLabs
LLM_ELEVENLABS_MAIN=sk_your-key-here

# ─── Optional: Grafana ────────────────────────────────────────
GRAFANA_PASSWORD=changeme
