# llm-exporter — Environment Variables
# Copy to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────
METRICS_PORT=9090
SCRAPE_INTERVAL=300        # seconds between probes (default: 5 min)
LOG_LEVEL=info             # debug | info | warn | error

# ─── Data directory (bind mounts) ─────────────────────────────
DATA_DIR=/opt/llm-exporter

# ─── Supabase (optional) ──────────────────────────────────────
# When set, keys are loaded from the credentials table (takes priority over config.yaml keys)
# Leave empty to use config.yaml only
SUPABASE_URL=
SUPABASE_KEY=

# ─── Grafana (full profile only) ──────────────────────────────
GRAFANA_PASSWORD=changeme
